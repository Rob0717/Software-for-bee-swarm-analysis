{
  "name": "software-for-bee-swarm-analysis-fe",
  "version": "0.0.1",
  "description": "Frontend aplikace pro lokalizaci včelích rojů",
  "author": "Róbert Onder <robertonder@seznam.cz>",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 127.0.0.1 --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "lint-fix": "ng lint --fix",
    "build-pipeline": "npm run build && npm run lint",
    "generate:api": "tsx generate-types.ts",
    "split:dtos": "node scripts/split-dtos.js",
    "generate:dtos": "npm run generate:api && npm run split:dtos"
  },
  "dependencies": {
    "@angular/animations": "20.3.17",
    "@angular/common": "20.3.17",
    "@angular/compiler": "20.3.17",
    "@angular/core": "20.3.17",
    "@angular/forms": "20.3.17",
    "@angular/platform-browser": "20.3.17",
    "@angular/platform-browser-dynamic": "20.3.17",
    "@angular/router": "20.3.17",
    "@jsverse/transloco": "8.2.1",
    "@primeuix/themes": "1.2.1",
    "leaflet": "1.9.4",
    "primeicons": "7.0.0",
    "primeng": "20.0.0",
    "rxjs": "7.8.1",
    "tailwindcss-primeui": "0.6.1",
    "tslib": "2.8.1",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.18",
    "@angular-eslint/eslint-plugin": "20.1.1",
    "@angular-eslint/eslint-plugin-template": "20.1.1",
    "@angular-eslint/template-parser": "20.1.1",
    "@angular/cli": "20.3.18",
    "@angular/compiler-cli": "20.3.17",
    "@eslint/js": "9.30.1",
    "@tailwindcss/postcss": "4.1.13",
    "@types/leaflet": "1.9.20",
    "@types/node": "22.19.1",
    "@typescript-eslint/eslint-plugin": "8.36.0",
    "@typescript-eslint/parser": "8.36.0",
    "angular-eslint": "20.1.1",
    "eslint": "9.30.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "51.3.4",
    "eslint-plugin-tsc": "2.0.0",
    "globals": "16.3.0",
    "openapi-typescript": "7.10.1",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.13",
    "tsx": "4.20.6",
    "typescript": "5.8.3",
    "typescript-eslint": "8.36.0"
