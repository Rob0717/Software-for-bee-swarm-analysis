# JWT secret key for access token
JWT_ACCESS_SECRET=

# Duration of JWT access token signature
JWT_ACCESS_SECRET_DURATION=1h

# Max age of cookie containing JWT access token (hours)
JWT_ACCESS_SECRET_COOKIE_MAX_AGE=1

# JWT secret key for account verification
JWT_ACCOUNT_VERIFY_SECRET=

# Duration of JWT verify token signature
JWT_ACCOUNT_VERIFY_SECRET_DURATION=1h

# JWT secret key for password reset
JWT_RESET_PASSWORD_SECRET=

# Duration of JWT password token signature
JWT_RESET_PASSWORD_SECRET_DURATION=1h

# Frontend application URL
FRONTEND_URL=http://127.0.0.1:4200

# Backend application URL
BACKEND_URL=http://127.0.0.1:3000

# Backend application PORT
BACKEND_PORT=3000

# development/production
NODE_ENV=development

# Database connection configuration
DB_HOSTNAME=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=my_database
MYSQL_ROOT_PASSWORD=

# Email service configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# User agent required for Nominatim request
USER_AGENT='software-for-bee-swarm-analysis/1.0 (<email>)'