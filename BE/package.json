{
  "name": "software-for-bee-swarm-analysis-be",
  "version": "0.0.1",
  "description": "Backend aplikace pro lokalizaci včelích rojů",
  "author": "Róbert Onder <robertonder@seznam.cz>",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build-pipeline": "npm run build && npm run lint",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./src/app-data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate ./src/migrations/InitSchema",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:docker": "node ./node_modules/typeorm/cli.js migration:run -d dist/app-data-source.js"
  },
  "dependencies": {
    "@nestjs/common": "11.1.12",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.12",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.12",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/typeorm": "11.0.0",
    "axios": "1.13.5",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "dotenv": "16.4.7",
    "geolib": "3.3.4",
    "multer": "2.1.0",
    "mysql2": "3.12.0",
    "nestjs-i18n": "10.6.0",
    "nodemailer": "7.0.11",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.28",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.0",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.7",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.0",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.2",
    "@types/nodemailer": "6.4.17",
    "@types/passport-jwt": "4.0.1",
    "eslint": "9.39.2",
    "globals": "15.14.0",
    "source-map-support": "0.5.21",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "overrides": {
    "lodash": "4.17.23",
    "serialize-javascript": "7.0.3",
    "multer": "2.1.0"
  }
}
